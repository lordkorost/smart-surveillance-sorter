{
    "config_files": {
        "cameras_path": "config/cameras.json",
        "prompts_path": "config/prompts.json",
        "models_dir": "models"
    },
    "city": "Rosarno",
    "classification_settings": {
        "priority_hierarchy": [
            "person",
            "animal",
            "vehicle"
        ],
        "save_others": true
    },
    "storage_settings": {
        "filename_template": "{nvr_name}_{camera_id}_{timestamp}",
        "timestamp_format": "%Y%m%d%H%M%S",
        "structure_type": "camera_first",
        "use_input_dir_as_output": true
    },
    "blip_settings": {
        "threshold": 0.5
    },
    "yolo_settings": {
        "model_path": "yolov8l",
        "device": "cpu",
        "num_occurrence": 3,
        "time_gap_sec": 3,
        "yolo_override_threshold": 0.85,
        "detection_groups": {
            "PERSON": [
                "person",
                "human"
            ],
            "ANIMAL": [
                "dog",
                "cat",
                "bird",
                "horse",
                "sheep",
                "cow",
                "bear"
            ],
            "VEHICLE": [
                "car",
                "truck",
                "motorcycle",
                "bicycle",
                "bus"
            ]
        },
        "vid_stride_sec": 0.6,
        "dynamic_stride_settings": {
            "warmup_sec": 5,
            "stride_fast_sec": 1.0,
            "pre_roll_sec": 20,
            "cooldown_sec": 5
        }
    },
    "vision_settings": {
        "model_name": "qwen3-vl:8b",
        "temperature": 1,
        "num_predict": 1024,
        "top_k": 20,
        "top_p": 0.95,
        "ollama_conf": {
            "ip": "127.0.0.1",
            "port": 11434
        }
    },
    "scoring_system": {
        "weights": {
            "score_high": 3.0,
            "score_mid": 2.2,
            "score_low": 1.2
        },
        "thresholds": {
            "person": 2.5,
            "animal": 10.0,
            "vehicle": 10.0
        },
        "multipliers": {
            "animal": 1.8,
            "vehicle": 1.5
        },
        "yolo_override": {
            "person_min_conf": 0.58,
            "min_total_score_to_skip_override": 1.2
        }
    },
    "output_mapping": {
        "person": "people",
        "animal": "animals",
        "vehicle": "vehicles",
        "nothing": "others"
    }
}